# Monad Testnet
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://testnet.monadvision.com

# Paste the deployed MonadPoP contract address here.
NEXT_PUBLIC_MONAD_POP_CONTRACT_ADDRESS=

# Server-only Groq configuration.
# Never rename this to NEXT_PUBLIC_GROQ_API_KEY.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local Prisma database.
DATABASE_URL=file:./dev.db

# Generate a long random value for signed sessions.
# Example command to generate: openssl rand -base64 32
AUTH_SECRET=

# Public application URL used in QR verification links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
