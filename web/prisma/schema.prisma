datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model ProductPassport {
  id                  String               @id @default(cuid())
  chainPassportId     Int                  @unique
  contractAddress     String
  chainId             Int
  productId           String               // hex representation of bytes32
  originalReceiptHash String               @unique
  merchantAddress     String
  originalBuyerAddress String
  currentOwnerAddress String
  purchasedAt         DateTime
  warrantyUntil       DateTime?
  status              String               // "Active", "Returned", "Refunded", "Replaced", "Revoked"
  
  // Public Product Metadata
  productName         String
  brand               String
  model               String
  imageUrl            String?
  description         String?
  merchantName        String
  metadataHash        String
  
  // Transactions
  issueTxHash         String
  statusTxHash        String?

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  // Relations
  privateData         PrivatePassportData?
  listings            Listing[]

  @@index([merchantAddress])
  @@index([currentOwnerAddress])
  @@index([originalReceiptHash])
}

model PrivatePassportData {
  id               String          @id @default(cuid())
  passportId       Int             @unique
  passport         ProductPassport @relation(fields: [passportId], references: [chainPassportId], onDelete: Cascade)
  
  // Encrypted fields (AES-256-GCM)
  encryptedPayload String          // holds encrypted JSON of serialNumber, receiptJson, sku, merchantReference, privateBuyerInfo, privateNotes, warrantyDocs
  iv               String
  tag              String

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Listing {
  id             String          @id @default(cuid())
  chainListingId Int             @unique
  passportId     Int
  passport       ProductPassport @relation(fields: [passportId], references: [chainPassportId])
  sellerAddress  String
  buyerAddress   String?
  price          String          // Price in MON (wei as string)
  metadataHash   String
  saleProofHash  String?
  status         String          // "Active", "Requested", "Accepted", "Completed", "Cancelled"
  escrowStatus   String          // "None", "Funded", "Refunded", "Settled"
  
  createdAt      DateTime        @default(now())
  acceptedAt     DateTime?
  completedAt    DateTime?
  
  createTxHash   String?
  actionTxHash   String?         // Hash for cancel, request, accept, reject, confirm

  @@index([passportId])
  @@index([sellerAddress])
  @@index([buyerAddress])
}

model MerchantProfile {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  displayName   String
  storeCode     String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
